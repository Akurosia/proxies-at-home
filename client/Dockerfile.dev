FROM node:24-alpine

# Work inside the client app directory
WORKDIR /app/client

# Install client dependencies (including devDependencies)
COPY client/package*.json ./
# Copy shared code/types so imports can resolve
COPY shared /app/shared
RUN npm install

# Copy the rest of the client source code
COPY client/. .

ENV NODE_ENV=development

EXPOSE 5173

# Run the client's own dev script (defined in client/package.json)
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
