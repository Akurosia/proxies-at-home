FROM node:24-alpine

# System deps needed for node-gyp + canvas (used by server)
RUN apk add --no-cache \
    python3 \
    make \
    g++ \
    cairo-dev \
    pango-dev \
    jpeg-dev \
    giflib-dev \
    pixman-dev

# Work inside the server app directory
WORKDIR /app/server

# Install server dependencies (including devDependencies)
COPY server/package*.json ./
# Copy shared code/types so TypeScript can resolve imports like ../shared
COPY shared /app/shared
RUN npm install

# Copy the rest of the server source code
COPY server/. .

ENV NODE_ENV=development
ENV PORT=3001

EXPOSE 3001

# Run the server's own dev script (defined in server/package.json)
CMD ["npm", "run", "dev"]
